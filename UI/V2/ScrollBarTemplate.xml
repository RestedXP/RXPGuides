<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
UI.xsd">
    <Button name="RXPV2ScrollUpButtonTemplate" virtual="true">
        <Size x="16" y="16"/>
        <NormalTexture parentKey="Normal" file="Interface\Addons\RXPGuides\Textures\v2\scrollbar_up"/>
        <!-- <PushedTexture parentKey="Pushed" file="Interface\Buttons\UI-ScrollBar-ScrollUpButton-Down"/> -->
        <!-- <DisabledTexture parentKey="Disabled" file="Interface\Buttons\UI-ScrollBar-ScrollUpButton-Disabled"/> -->
        <HighlightTexture parentKey="Highlight" file="Interface\Buttons\ButtonHilight-Square" alphaMode="ADD"/>
    </Button>
    <Button name="RXPV2ScrollDownButtonTemplate" virtual="true">
        <Size x="16" y="16"/>
        <NormalTexture parentKey="Normal" file="Interface\Addons\RXPGuides\Textures\v2\scrollbar_down"/>
        <!-- <PushedTexture parentKey="Pushed" file="Interface\Buttons\UI-ScrollBar-ScrollDownButton-Down"/> -->
        <!-- <DisabledTexture parentKey="Disabled" file="Interface\Buttons\UI-ScrollBar-ScrollDownButton-Disabled"/> -->
        <HighlightTexture parentKey="Highlight" file="Interface\Buttons\ButtonHilight-Square" alphaMode="ADD"/>
    </Button>
	<Slider name="RXPV2ScrollBarTemplate" virtual="true">
		<Size x="16" y="0"/>
		<Frames>
			<Button name="$parentScrollUpButton" parentKey="ScrollUpButton" inherits="RXPV2ScrollUpButtonTemplate">
				<Anchors>
					<Anchor point="BOTTOM" relativePoint="TOP"/>
				</Anchors>
				<Scripts>
					<OnClick function="UIPanelScrollBarScrollUpButton_OnClick"/>
				</Scripts>
			</Button>
			<Button name="$parentScrollDownButton" parentKey="ScrollDownButton" inherits="RXPV2ScrollDownButtonTemplate">
				<Anchors>
					<Anchor point="TOP" relativePoint="BOTTOM"/>
				</Anchors>
				<Scripts>
					<OnClick function="UIPanelScrollBarScrollDownButton_OnClick"/>
				</Scripts>
			</Button>
		</Frames>
		<Scripts>
			<OnValueChanged function="UIPanelScrollBar_OnValueChanged"/>
		</Scripts>
		<ThumbTexture name="$parentThumbTexture" parentKey="ThumbTexture" file="Interface\Addons\RXPGuides\Textures\v2\scrollbar_knob">
			<Size x="16" y="16"/>
			<TexCoords left="0.20" right="0.80" top="0.20" bottom="0.80"/>
		</ThumbTexture>
	</Slider>
</Ui>
